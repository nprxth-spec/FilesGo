// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  image              String?
  credits            Int       @default(9999)
  plan               String    @default("free") // "free" | "pro"
  lastCreditsReset   DateTime? // last time free-plan credits were reset to 9999
  sheetId            String?
  sheetName          String?
  sheetMapping       Json?
  filenameMapping    Json?
  sheetProfiles      Json?
  activeSheetProfileId String?
  driveFolderId      String?
  accounts           Account[]
  sessions           Session[]
  logs               ProcessingLog[]
  auditLogs          AuditLog[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProcessingLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename         String   // display name (may include mapping + billed_to)
  originalFilename String?  // name as uploaded; used for duplicate detection
  invoiceDate      String?
  cardLast4   String?
  amount      Float?
  currency    String?
  driveLink   String?
  sheetRow    Int?
  status      String   @default("success")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, originalFilename, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "login" | "config_drive" | "config_sheet" | "config_naming" | "config_plan"
  description String?
  metadata    Json?    // optional extra (e.g. what changed)
  ip          String?  // client IP when available
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([type])
}
